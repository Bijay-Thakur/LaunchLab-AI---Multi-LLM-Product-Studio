# Project-root .env example. Copy to .env and fill in real values.
# .env is gitignored. Never commit real keys.
#
# === Backend (Flask) - server-side only, never exposed to frontend ===

GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional - override defaults
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_TIMEOUT=60
# Demo kill-switch for OpenAI image generation. Default OFF so paid quota
# cannot be burned accidentally during a class run. Set to "true" to turn the
# real image API on; the hero image still only auto-generates once.
ENABLE_IMAGE_GENERATION=false
OPENAI_TIMEOUT=45
GEMINI_TIMEOUT=45
FLASK_ENV=development

# CORS allow-list. Single URL or comma-separated list of frontend origins.
# Example: FRONTEND_URL=http://localhost:3000,https://launchlab.example.com
FRONTEND_URL=http://localhost:3000

# === Optional backend Supabase (server-only) ===
# Only set the service-role key if you add backend admin tasks. Never expose
# it to the frontend. The default frontend flow uses RLS + the anon key only.
# SUPABASE_URL=your_supabase_project_url
# SUPABASE_SERVICE_ROLE_KEY=backend_only_never_frontend

# === Frontend (Next.js) - put these in frontend/.env.local ===
# Only NEXT_PUBLIC_ vars are safe to expose to the browser.

# NEXT_PUBLIC_API_URL=http://localhost:5000/api
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
