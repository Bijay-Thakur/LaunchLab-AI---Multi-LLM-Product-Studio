# Optional: backend-only env overrides. The backend reads the project-root
# .env first, so you usually only need to fill the root .env.example.

GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_TIMEOUT=60
# Demo kill-switch. Default OFF.
ENABLE_IMAGE_GENERATION=false
OPENAI_TIMEOUT=45
GEMINI_TIMEOUT=45
FLASK_ENV=development

# CORS allow-list. Single URL or comma-separated list.
FRONTEND_URL=http://localhost:3000

# Optional backend Supabase (server-only). Service-role key must NEVER be
# exposed to the frontend. Leave blank unless you add admin tasks.
# SUPABASE_URL=your_supabase_project_url
# SUPABASE_SERVICE_ROLE_KEY=backend_only_never_frontend
