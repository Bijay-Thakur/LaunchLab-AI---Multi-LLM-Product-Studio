# Frontend env. Copy to frontend/.env.local. Only NEXT_PUBLIC_* is exposed to the browser.

NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Supabase (optional). If unset, the app runs in local demo mode without auth/save.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
